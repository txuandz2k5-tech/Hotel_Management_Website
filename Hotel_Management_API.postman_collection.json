{
  "info": {
    "name": "Hotel Management API",
    "description": "RESTful API for Hotel Management System with Role-Based Access Control\n\n🔐 AUTHENTICATION:\n- Login with username/password to get JWT token\n- Use Bearer token in Authorization header\n\n👥 ROLES & PERMISSIONS:\n- ADMIN: Full access to all endpoints\n- GUEST: Bookings and Service Orders only\n- STAFF: Limited access (same as guest)\n\n📋 ENDPOINTS:\n- Authentication: Login, logout, get current user\n- Guests: Admin only\n- Bookings: Guest + Admin\n- Rooms/Room Types/Services: View (all), Manage (admin only)\n- Service Orders: Guest + Admin (new feature)\n- Employees/Departments/Payments/Discounts/Accounts: Admin only",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/Hotel_Management_Website"
    },
    {
      "key": "jwt_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"<username_or_phone>\",\n  \"password\": \"<password>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login to get JWT token. Use the same endpoint for admin, staff, and guest. For guest, username is phone number."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', response.data.token);",
                  "    console.log('Token saved:', response.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        }
      ]
    },
