              "raw": "{{base_url}}/api/v1/service-orders?booking_id=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "service-orders"],
              "query": [
                {
                  "key": "booking_id",
                  "value": "BD001"
